{
  "version": 1,
  "author": "EspOS Virtual Lab",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-s3-devkitc-1", "id": "esp", "top": 0, "left": 0 },
    { "type": "board-ssd1306", "id": "oled", "top": -10, "left": 220 },
    { "type": "wokwi-analog-joystick", "id": "joy", "top": 140, "left": 220 }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", ""],
    ["esp:RX", "$serialMonitor:TX", ""],
    ["esp:8", "oled:SDA", "green", ["v-10"]],
    ["esp:9", "oled:SCL", "blue", ["v-20"]],
    ["oled:VCC", "esp:3V3", "red"],
    ["oled:GND", "esp:GND", "black"],
    ["joy:VCC", "esp:3V3", "red"],
    ["joy:GND", "esp:GND", "black"],
    ["joy:HORZ", "esp:1", "orange"],
    ["joy:VERT", "esp:2", "yellow"]
  ]
}
